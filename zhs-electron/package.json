{
  "name": "zhs-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Electron port of Autovisor with a native task panel and embedded Zhihuishu browser.",
  "author": "ZHS Autovisor",
  "main": "out/main/index.js",
  "packageManager": "npm@11.3.0",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && electron-vite build",
    "build:mac": "npm run build && electron-builder --mac dmg --arm64 --x64",
    "build:win": "npm run build && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
